# .envrc — direnv config for tracking your Claude Code time on Shyre.
#
# Copy to `.envrc` (git-ignored), fill in SHYRE_API_KEY, then: direnv allow
# Requires direnv (https://direnv.net — `brew install direnv` + shell hook).
#
# direnv loads these into your shell whenever you `cd` into this repo, and
# `claude` launched from here inherits them — so the session hooks and the
# MCP server can resolve ${SHYRE_API_KEY}. (Claude Code does NOT read
# .env.local, which is why the env var has to be exported like this.)

# Personal access token from /settings/integrations. Shown once — save it
# to your password manager too. Scope it to log time entries.
export SHYRE_API_KEY="shyre_pat_REPLACE_ME"

# Internal "Shyre" project these sessions log to. Pre-filled to the
# existing Shyre project; change it to point at a different project.
export SHYRE_PROJECT_ID="ab8697ca-58ff-4c70-bb9a-df29936e7307"
