# Route @theshyre/* imports to GitHub Packages.
#
# Auth uses the NODE_AUTH_TOKEN env var at install time:
#   - CI: setup-node injects it from secrets.GITHUB_TOKEN (see
#     .github/workflows/ci.yml).
#   - Vercel: set NODE_AUTH_TOKEN as a project env var (Production +
#     Preview + Development) to a classic PAT with read:packages scope.
#   - Local dev: export NODE_AUTH_TOKEN in your shell (or add to
#     ~/.zshenv / ~/.bash_profile). A per-user ~/.npmrc line will
#     be ignored here because this project .npmrc takes precedence.
@theshyre:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
