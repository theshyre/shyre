# Supabase — app credentials
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase CLI — for running migrations via `npm run db:push`
# Create at https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_...

# Session pooler URI from Supabase dashboard → Connect → URI tab.
# IMPORTANT: must be the SESSION pooler (port 5432), not transaction (6543).
SUPABASE_DB_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres

# Messaging (Phase 1: invoice email)
# 32-byte hex key for AES-256-GCM encryption of stored email API keys.
# Generate with: openssl rand -hex 32
# Lose this key = stored API keys become unrecoverable; users re-paste.
EMAIL_KEY_ENCRYPTION_KEY=
# Resend webhook signing secret (set in Resend dashboard → Webhooks). `whsec_`-prefixed.
RESEND_WEBHOOK_SECRET=
