{
  "name": "shyre",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ci:local": "npm run lint && npm run typecheck && npm run test:coverage && npm run build",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "vitest --config vitest.integration.config.ts",
    "test:all": "npm run test && npm run test:integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "cleanup:test-data": "tsx src/__integration__/helpers/cleanup-cli.ts",
    "db:link": "supabase link --project-ref onbdbngemtbrnstjnbns",
    "db:push": "bash scripts/db-push.sh",
    "db:status": "bash scripts/db-status.sh",
    "db:new": "supabase migration new",
    "db:backup": "bash scripts/db-backup.sh",
    "seed:company": "tsx --env-file=.env.local scripts/seed-company-time-log.ts",
    "setup:company": "npm run db:push && npm run seed:company"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@react-pdf/renderer": "^4.4.1",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.103.0",
    "@theshyre/design-tokens": "^0.7.2",
    "@theshyre/theme": "^0.2.0",
    "@theshyre/ui": "^0.12.1",
    "geist": "^1.7.0",
    "lucide-react": "^1.8.0",
    "mcp-handler": "^1.1.0",
    "mdast-util-to-string": "^4.0.0",
    "next": "^16.2.6",
    "next-intl": "^4.9.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "server-only": "^0.0.1",
    "unified": "^11.0.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "^16.2.6",
    "jsdom": "^29.0.2",
    "nanoid": "^5.1.7",
    "supabase": "^2.90.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^6",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "eslint-plugin-react-hooks": "7.0.1"
  }
}
